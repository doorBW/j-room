# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Node (자동화 스크립트용)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.env
.env.local
.env.*.local

# Python (스크립트용)
__pycache__/
*.pyc
.venv/
venv/

# AI 도구 캐시
.canva-cache/
.figma-cache/
.bannerbear-cache/

# 임시 파일
*.tmp
*.bak
*~

# 카드 생성 결과물 (재생성 가능)
pipeline/output/
pipeline/preview.html

# 외부 저작권 이미지 (매장 포스터) — 로컬에서만, SOURCES.md만 버전관리
assets/images/*/*.png
assets/images/*/*.jpg
assets/images/*/*.jpeg
assets/images/*/*.webp
!assets/images/*/SOURCES.md

# 대용량 원본 (필요시 LFS 또는 외부 스토리지)
assets/raw/
*.psd
*.ai
*.sketch

# 비밀
secrets/
*.key
*.pem
credentials.json

# OMC 작업 캐시
.omc/
# .claude 직속은 무시하되, 인스타 운영 스킬은 버전 관리
.claude/*
!.claude/skills/
